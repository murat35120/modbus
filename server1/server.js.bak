</head>
<body>
    <div class="app-container" id="app">
        <!-- Левый блок -->
        <div class="left-panel">
            <div class="panel-header">
                <h3>🔍 Оборудование</h3>
                <div class="udp-control">
                    <button class="btn-toggle active" id="udpToggle" onclick="toggleUdp()">
