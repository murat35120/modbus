            <!-- Конвертеры клиент -->
            <div class="list-section">
                <div class="list-section-title">🔄 Клиенты (${clientConverters.length})</div>
                <div class="converter-list" id="clientList">
                    ${clientConverters.map(c => renderConverterItem(c)).join('')}
                </div>
            </div>
        </div>
        
        <!-- Центральный блок -->
        <div class="center-panel" id="centerPanel">
            <div class="info-header">
                <div>
                    <div class="info-title" id="infoTitle">Выберите конвертер</div>
                    <div class="info-subtitle" id="infoSubtitle">Нажмите на конвертер в списке слева</div>
                </div>
                <div>
                    <span class="badge" id="statusBadge">● Ожидание</span>
                </div>
            </div>
            
            <div class="info-grid" id="infoGrid">
                <div class="info-item">
                    <div class="label">Серийный номер</div>
                    <div class="value" id="snValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">IP адрес</div>
                    <div class="value" id="ipValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">Версия прошивки</div>
                    <div class="value" id="versionValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">Режим</div>
                    <div class="value" id="modeValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">L1 Порт</div>
                    <div class="value" id="l1PortValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">L2 Порт</div>
                    <div class="value" id="l2PortValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">L1 Соединение</div>
                    <div class="value" id="l1ConnValue">—</div>
                </div>
                <div class="info-item">
                    <div class="label">L2 Соединение</div>
                    <div class="value" id="l2ConnValue">—</div>
                </div>
            </div>
            
            <div class="controls-section">
                <div class="controls-row">
                    <select id="speedSelect">
                        <option value="230400">230400</option>
                        <option value="115200">115200</option>
                        <option value="38400" selected>38400</option>
                        <option value="19200">19200</option>
                        <option value="9600">9600</option>
                    </select>
                    <button class="btn btn-primary" onclick="applySpeed()">Применить скорость</button>
                    <button class="btn btn-success" id="connectBtn" onclick="toggleConnection()">Подключить</button>
                    <button class="btn btn-danger" onclick="deleteConverter()">🗑 Удалить</button>
                    <button class="btn btn-outline" onclick="refreshInfo()">🔄 Обновить</button>
                </div>
            </div>
        </div>
        
        <!-- Правый блок -->
        <div class="right-panel">
            <div class="panel-header">
                <h3>🎮 Контроллеры</h3>
            </div>
            <div class="controller-list" id="controllerList">
                <div class="empty-state">
                    <span class="icon">📡</span>
                    Подключитесь к конвертеру<br>для сканирования контроллеров
                </div>
            </div>
        </div>
    </div>
    
    <script>
        let selectedConverter = null;
        let converters = [];
        let isConnected = false;
        
        // Рендер элемента конвертера
        function renderConverterItem(converter) {
            const statusClass = converter.connected ? 'connected' : 'disconnected';
            const modeClass = converter.mode === 'server' ? 'server' : 'client';
            const busyClass = converter.busy ? 'busy' : '';
            const deletedClass = converter.deleted ? 'deleted' : '';
            
            return \`
                <div class="converter-item \${selectedConverter === converter.serialNumber ? 'selected' : ''}" 
                     onclick="selectConverter('\${converter.serialNumber}')"
                     data-sn="\${converter.serialNumber}">
                    <div class="name">\${converter.model} \${converter.serialNumber}</div>
                    <div class="ip">\${converter.ip}</div>
                    <span class="badge \${statusClass}">\${converter.connected ? '● Подключен' : '○ Отключен'}</span>
                    <span class="badge \${modeClass}">\${converter.mode === 'server' ? '📡 Сервер' : '🔄 Клиент'}</span>
                    \${converter.busy ? '<span class="badge busy">🔒 Занят</span>' : ''}
                    \${converter.deleted ? '<span class="badge deleted">🗑 Удален</span>' : ''}
                </div>
            \`;
        }
        
        // Выбор конвертера
        function selectConverter(serialNumber) {
            selectedConverter = serialNumber;
            updateUI();
            loadConverterInfo(serialNumber);
        }
        
        // Загрузка информации о конвертере
        async function loadConverterInfo(serialNumber) {
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: 'get',
                        data: { serialNumber }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    updateInfoPanel(data.result);
                    updateControllerList(data.result);
                }
            } catch (error) {
                console.error('Error loading converter info:', error);
            }
        }
        
        // Обновление панели информации
        function updateInfoPanel(converter) {
            document.getElementById('infoTitle').textContent = \`\${converter.model} \${converter.serialNumber}\`;
            document.getElementById('infoSubtitle').textContent = \`Последнее обновление: \${new Date(converter.lastSeen).toLocaleString()}\`;
            
            document.getElementById('snValue').textContent = converter.serialNumber || '—';
            document.getElementById('ipValue').textContent = converter.ip || '—';
            document.getElementById('versionValue').textContent = converter.version || '—';
            document.getElementById('modeValue').textContent = converter.mode === 'server' ? 'Сервер' : 'Клиент';
            document.getElementById('l1PortValue').textContent = converter.L1_Port || '—';
            document.getElementById('l2PortValue').textContent = converter.L2_Port || '—';
            document.getElementById('l1ConnValue').textContent = converter.L1_Conn || '—';
            document.getElementById('l2ConnValue').textContent = converter.L2_Conn || '—';
            
            const badge = document.getElementById('statusBadge');
            if (converter.connected) {
                badge.textContent = '● Подключен';
                badge.style.color = '#10b981';
            } else if (converter.busy) {
                badge.textContent = '🔒 Занят';
                badge.style.color = '#f59e0b';
            } else if (converter.deleted) {
                badge.textContent = '🗑 Удален';
                badge.style.color = '#6b7280';
            } else {
                badge.textContent = '○ Отключен';
                badge.style.color = '#ef4444';
            }
            
            // Обновляем кнопку подключения
            const connectBtn = document.getElementById('connectBtn');
            if (converter.connected) {
                connectBtn.textContent = 'Отключить';
                connectBtn.className = 'btn btn-danger';
            } else {
                connectBtn.textContent = 'Подключить';
                connectBtn.className = 'btn btn-success';
            }
            
            // Обновляем выбранную скорость
            document.getElementById('speedSelect').value = converter.workingSpeed || 38400;
            
            isConnected = converter.connected;
        }
        
        // Обновление списка контроллеров
        function updateControllerList(converter) {
            const container = document.getElementById('controllerList');
            if (converter.connected) {
                container.innerHTML = \`
                    <div class="empty-state">
                        <span class="icon">🔍</span>
                        Сканирование контроллеров...
                        <button class="btn btn-primary" style="margin-top: 12px;" onclick="scanControllers()">
                            Начать сканирование
                        </button>
                    </div>
                \`;
            } else {
                container.innerHTML = \`
                    <div class="empty-state">
                        <span class="icon">📡</span>
                        Подключитесь к конвертеру<br>для сканирования контроллеров
                    </div>
                \`;
            }
        }
        
        // Сканирование контроллеров
        async function scanControllers() {
            if (!selectedConverter) return;
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'controller',
                        cmd: 'scan',
                        data: { serialNumber: selectedConverter }
                    })
                });
                const data = await response.json();
                // Обновляем список контроллеров
                console.log('Scan result:', data);
            } catch (error) {
                console.error('Error scanning controllers:', error);
            }
        }
        
        // Переключение UDP поиска
        async function toggleUdp() {
            const btn = document.getElementById('udpToggle');
            const isActive = btn.classList.contains('active');
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'server',
                        cmd: 'updateSettings',
                        data: { udpSearchEnabled: !isActive }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    btn.classList.toggle('active');
                    btn.classList.toggle('inactive');
                    btn.textContent = \`Поиск: \${btn.classList.contains('active') ? 'Вкл' : 'Выкл'}\`;
                }
            } catch (error) {
                console.error('Error toggling UDP:', error);
            }
        }
        
        // Применить скорость
        async function applySpeed() {
            if (!selectedConverter) {
                alert('Выберите конвертер');
                return;
            }
            
            const speed = document.getElementById('speedSelect').value;
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: 'setSpeed',
                        data: { serialNumber: selectedConverter, speed: parseInt(speed) }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    alert('Скорость успешно изменена');
                    loadConverterInfo(selectedConverter);
                }
            } catch (error) {
                console.error('Error applying speed:', error);
                alert('Ошибка применения скорости');
            }
        }
        
        // Подключение/отключение
        async function toggleConnection() {
            if (!selectedConverter) {
                alert('Выберите конвертер');
                return;
            }
            
            const cmd = isConnected ? 'disconnect' : 'connect';
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: cmd,
                        data: { serialNumber: selectedConverter }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    loadConverterInfo(selectedConverter);
                }
            } catch (error) {
                console.error('Error toggling connection:', error);
                alert('Ошибка переключения соединения');
            }
        }
        
        // Удалить конвертер
        async function deleteConverter() {
            if (!selectedConverter) {
                alert('Выберите конвертер');
                return;
            }
            
            if (!confirm('Удалить конвертер ' + selectedConverter + '?')) return;
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: 'delete',
                        data: { serialNumber: selectedConverter }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    selectedConverter = null;
                    loadConverterList();
                    document.getElementById('infoTitle').textContent = 'Выберите конвертер';
                    document.getElementById('infoSubtitle').textContent = 'Нажмите на конвертер в списке слева';
                }
            } catch (error) {
                console.error('Error deleting converter:', error);
                alert('Ошибка удаления конвертера');
            }
        }
        
        // Обновить информацию
        async function refreshInfo() {
            if (!selectedConverter) {
                alert('Выберите конвертер');
                return;
            }
            
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: 'updateInfo',
                        data: { serialNumber: selectedConverter }
                    })
                });
                const data = await response.json();
                if (data.success) {
                    loadConverterInfo(selectedConverter);
                }
            } catch (error) {
                console.error('Error refreshing info:', error);
                alert('Ошибка обновления информации');
            }
        }
        
        // Загрузка списка конвертеров
        async function loadConverterList() {
            try {
                const response = await fetch('/api', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        api: 'converter',
                        cmd: 'list',
                        data: {}
                    })
                });
                const data = await response.json();
                if (data.success) {
                    converters = data.result;
                    updateUI();
                }
            } catch (error) {
                console.error('Error loading converters:', error);
            }
        }
        
        // Обновление UI
        function updateUI() {
            const serverConverters = converters.filter(c => c.mode === 'server' && !c.deleted);
            const clientConverters = converters.filter(c => c.mode === 'client' && !c.deleted);
            
            // Обновляем заголовки
            document.querySelector('.list-section:first-child .list-section-title').textContent = 
                \`📡 Серверы (\${serverConverters.length})\`;
            document.querySelector('.list-section:last-child .list-section-title').textContent = 
                \`🔄 Клиенты (\${clientConverters.length})\`;
            
            // Рендерим списки
            const serverList = document.getElementById('serverList');
            const clientList = document.getElementById('clientList');
            
            serverList.innerHTML = serverConverters.map(c => renderConverterItem(c)).join('');
            clientList.innerHTML = clientConverters.map(c => renderConverterItem(c)).join('');
            
            // Выделяем выбранный
            if (selectedConverter) {
                document.querySelectorAll('.converter-item').forEach(el => {
                    el.classList.toggle('selected', el.dataset.sn === selectedConverter);
                });
            }
        }
        
        // Периодическое обновление
        setInterval(loadConverterList, 5000);
        
        // Загрузка при старте
        loadConverterList();
        
        // Если есть конвертеры, выбираем первый
        setTimeout(() => {
            if (converters.length > 0 && !selectedConverter) {
                selectConverter(converters[0].serialNumber);
            }
        }, 1000);
    </script>
</body>
</html>`;
    
    // Сохраняем страницу
    const equipmentPath = path.join(PATHS.pages, 'equipment.html');
    fs.writeFileSync(equipmentPath, html, 'utf8');
    console.log('📄 Страница оборудования создана');
}

// Генерируем страницу оборудования
generateEquipmentPage();

// Генерируем главную страницу
pageGenerator.generate();

console.log('\n✅ Приложение успешно запущено');